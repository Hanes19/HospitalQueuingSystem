<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F5F7FA">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Incoming Arrivals"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="20dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Unassigned Patient"
            android:textSize="14sp"
            android:textColor="#757575"/>

        <TextView
            android:id="@+id/textTriagePatientName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="John Doe"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/textTriageReason"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reason: Fever / General Illness"
            android:textSize="16sp"
            android:textColor="#D32F2F"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Assign Priority Level:"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <RadioGroup
            android:id="@+id/radioGroupPriority"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <RadioButton
                android:id="@+id/radioEmergency"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔴 EMERGENCY (See Immediately)"
                android:padding="8dp"/>

            <RadioButton
                android:id="@+id/radioUrgent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🟠 URGENT (See within 30 mins)"
                android:padding="8dp"/>

            <RadioButton
                android:id="@+id/radioStandard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🟢 STANDARD (Normal Queue)"
                android:padding="8dp"/>
        </RadioGroup>

        <Button
            android:id="@+id/btnAdmitPatient"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Admit to Waiting Room"
            android:textSize="16sp"/>

    </LinearLayout>
</LinearLayout>